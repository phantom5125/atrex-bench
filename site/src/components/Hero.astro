---
import operatorData from '../data/operators.json';
const { stats } = operatorData;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<section class="relative pt-16 pb-8 overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-b from-brand-950/20 to-transparent"></div>
  <div class="absolute top-10 left-1/2 -translate-x-1/2 w-[600px] h-[600px] bg-brand-700/5 rounded-full blur-3xl"></div>

  <div class="page-container relative">
    <div class="text-center max-w-4xl mx-auto py-14 sm:py-20">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-brand-900/30 border border-brand-800/50 text-brand-400 text-sm mb-8">
        <span class="w-2 h-2 rounded-full bg-brand-500 animate-pulse"></span>
        Early Stage
      </div>

      <h1 class="text-5xl sm:text-7xl font-bold text-white mb-4 tracking-tight" data-i18n="hero.title">
        Atrex-Bench
      </h1>

      <p class="text-xl sm:text-2xl text-brand-300 font-medium mb-6" data-i18n="hero.subtitle">
        End-to-End Operator Generation Benchmark for Multiple DSLs
      </p>

      <p class="text-gray-400 text-lg max-w-2xl mx-auto mb-10" data-i18n="hero.description">
        Production-trace driven benchmark for evaluating "agent platform + model" stacks on GPU kernel generation.
      </p>

      <div class="flex items-center justify-center gap-4 mb-16">
        <a href="https://github.com/alibaba/atrex-bench" target="_blank"
           class="inline-flex items-center gap-2 px-6 py-3 bg-brand-700 hover:bg-brand-600 text-white rounded-lg font-medium transition-colors">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          <span data-i18n="hero.cta.github">View on GitHub</span>
        </a>
        <a href={`${base}/doc/quickstart`}
           class="inline-flex items-center gap-2 px-6 py-3 bg-gray-800 hover:bg-gray-700 text-white rounded-lg font-medium transition-colors border border-gray-700">
          <span data-i18n="hero.cta.quickstart">Quick Start</span>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
        </a>
      </div>

      <div class="grid grid-cols-3 gap-4 max-w-2xl mx-auto">
        <div class="card text-center">
          <div class="text-3xl sm:text-4xl font-bold text-brand-400">{stats.operators}</div>
          <div class="text-sm text-gray-400 mt-1" data-i18n="hero.stat.operators">Production Operators</div>
        </div>
        <div class="card text-center">
          <div class="text-3xl sm:text-4xl font-bold text-brand-400">{stats.shapes}</div>
          <div class="text-sm text-gray-400 mt-1" data-i18n="hero.stat.shapes">Hot Shapes</div>
        </div>
        <div class="card text-center">
          <div class="text-3xl sm:text-4xl font-bold text-brand-400">{(stats.traces_profiled / 1000).toFixed(1)}k</div>
          <div class="text-sm text-gray-400 mt-1">
            Prod. Profiles
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
