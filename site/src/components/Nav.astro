---
interface Props {
  currentPath: string;
}
const { currentPath } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const docPages = [
  { href: `${base}/doc/overview`,   key: 'nav.overview',    label: 'Overview' },
  { href: `${base}/doc/quickstart`, key: 'nav.quickstart',  label: 'Quick Start' },
  { href: `${base}/doc/format`,     key: 'nav.format',      label: 'Data Format' },
];

function isActive(href: string): boolean {
  const norm = href.replace(/\/$/, '') || '/';
  const cur = currentPath.replace(/\/$/, '').replace(base.replace(/\/$/, ''), '') || '/';
  const target = norm.replace(base.replace(/\/$/, ''), '') || '/';
  return cur === target;
}

const isDocActive = docPages.some(p => isActive(p.href));
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-gray-950/80 backdrop-blur-lg border-b border-gray-800/50">
  <div class="page-container">
    <div class="flex items-center justify-between h-16">
      <a href={`${base}/`} class="flex items-center gap-2 shrink-0">
        <div class="w-8 h-8 bg-brand-700 rounded-lg flex items-center justify-center font-bold text-white text-sm">A</div>
        <span class="font-bold text-white text-lg hidden sm:inline">Atrex-Bench</span>
      </a>

      <!-- Desktop nav -->
      <div class="hidden md:flex items-center gap-6">
        <a href={`${base}/`}
           class={`text-sm transition-colors ${isActive(`${base}/`) ? 'text-white font-medium' : 'text-gray-400 hover:text-white'}`}
           data-i18n="nav.home">Home</a>

        <a href={`${base}/data`}
           class={`text-sm transition-colors ${isActive(`${base}/data`) ? 'text-white font-medium' : 'text-gray-400 hover:text-white'}`}
           data-i18n="nav.data">Data</a>

        <!-- Doc dropdown -->
        <div class="relative" id="doc-dropdown">
          <button
            id="doc-dropdown-btn"
            class={`text-sm transition-colors flex items-center gap-1 ${isDocActive ? 'text-white font-medium' : 'text-gray-400 hover:text-white'}`}>
            <span data-i18n="nav.doc">Doc</span>
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </button>
          <div id="doc-dropdown-menu" class="hidden absolute top-full left-0 mt-2 w-44 bg-gray-900 border border-gray-800 rounded-lg shadow-xl py-1 z-50">
            {docPages.map(p => (
              <a href={p.href}
                 class={`block px-4 py-2 text-sm transition-colors ${isActive(p.href) ? 'text-white bg-gray-800' : 'text-gray-400 hover:text-white hover:bg-gray-800/50'}`}
                 data-i18n={p.key}>
                {p.label}
              </a>
            ))}
          </div>
        </div>

        <div class="flex items-center gap-1 ml-3 bg-gray-800 rounded-full px-1 py-0.5">
          <button data-lang-btn="en" class="text-xs px-2.5 py-1 rounded-full transition-colors text-white">EN</button>
        </div>

        <a href="https://github.com/alibaba/atrex-bench"
           target="_blank" rel="noopener noreferrer"
           class="text-gray-400 hover:text-white transition-colors ml-1">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        </a>
      </div>

      <!-- Mobile hamburger -->
      <button id="mobile-menu-btn" class="md:hidden text-gray-400 hover:text-white">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-gray-800">
    <div class="page-container py-3 space-y-1">
      <a href={`${base}/`}
         class={`block text-sm py-2 ${isActive(`${base}/`) ? 'text-white font-medium' : 'text-gray-400'}`}
         data-i18n="nav.home">Home</a>
      <a href={`${base}/data`}
         class={`block text-sm py-2 ${isActive(`${base}/data`) ? 'text-white font-medium' : 'text-gray-400'}`}
         data-i18n="nav.data">Data</a>

      <div class="text-xs text-gray-500 uppercase tracking-wider pt-2 pb-1" data-i18n="nav.doc">Doc</div>
      {docPages.map(p => (
        <a href={p.href}
           class={`block text-sm py-2 pl-4 ${isActive(p.href) ? 'text-white font-medium' : 'text-gray-400'}`}
           data-i18n={p.key}>
          {p.label}
        </a>
      ))}

      <div class="flex items-center gap-2 pt-2 border-t border-gray-800/50 mt-2">
        <button data-lang-btn="en" class="text-xs px-3 py-1 rounded-full bg-gray-800 text-white">EN</button>
      </div>
    </div>
  </div>
</nav>

<script>
  // Mobile menu toggle
  document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
    document.getElementById('mobile-menu')?.classList.toggle('hidden');
  });
  document.querySelectorAll('#mobile-menu a').forEach(a => {
    a.addEventListener('click', () => document.getElementById('mobile-menu')?.classList.add('hidden'));
  });

  // Desktop Doc dropdown
  const btn = document.getElementById('doc-dropdown-btn');
  const menu = document.getElementById('doc-dropdown-menu');
  if (btn && menu) {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      menu.classList.toggle('hidden');
    });
    document.addEventListener('click', () => menu.classList.add('hidden'));
    menu.addEventListener('click', (e) => e.stopPropagation());
  }
</script>
